# Copy this file to server/.env and fill in the blanks.
# server/.env is gitignored — never commit real credentials.
#
# QUOTING: wrap any value in SINGLE QUOTES if it starts with '#' or contains
# spaces/special characters — otherwise dotenv treats '#...' as a comment and the
# value parses as empty. Single quotes keep the value fully literal, e.g.:
#   APP_PASSPHRASE='#myStr0ng-Pa$$phrase!'

# App passphrase — gates access to the webmail UI.
# Separate from the mailbox password. Choose a strong value.
APP_PASSPHRASE=

# Secret used to sign the session cookie and CSRF tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Namecheap Private Email mailbox credentials.
# MAIL_USER is the full address; MAIL_PASSWORD is the mailbox password.
# (Quote MAIL_PASSWORD too if it starts with '#' or has special characters.)
MAIL_USER=contact@arnabray.me
MAIL_PASSWORD=

# IMAP (implicit TLS).
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993

# SMTP (implicit TLS; fallback 587 STARTTLS).
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465

# HTTP port for the Fastify API server.
PORT=3001
